# GitHub Models (LLM inference — OpenAI-compatible)
GITHUB_TOKEN=
GITHUB_MODEL=gpt-4o-mini
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com

# Frontend origins allowed to call the API (CORS).
# Local default is localhost:3000; in production set this to your Vercel URL.
FRONTEND_ORIGINS=http://localhost:3000

# Langfuse (observability — optional; nodes trace only when these are set)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Supabase (Postgres — persists research runs). Run schema.sql once in the
# Supabase SQL editor. Leave blank to run without persistence.
SUPABASE_URL=
SUPABASE_KEY=

